generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  ADMIN
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TimeBlockType {
  BOOKING
  TRAVEL
  MANUAL_BLOCK
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum TenantPlan {
  STARTER
  PRO
  SCALE
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id                   String       @id @default(cuid())
  slug                 String       @unique
  name                 String
  subdomain            String?      @unique
  customDomain         String?      @unique
  status               TenantStatus @default(TRIAL)
  plan                 TenantPlan   @default(STARTER)
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?      @unique
  stripeAccountId      String?      @unique // Stripe Connect — conta da empresa
  stripeAccountStatus  String? // "pending" | "active" | "restricted"
  platformFeePercent   Decimal      @default(10.00) @db.Decimal(5, 2) // taxa da plataforma
  trialEndsAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  settings      TenantSettings?
  users         User[]
  properties    Property[]
  bookings      Booking[]
  teams         Team[]
  timeBlocks    TimeBlock[]
  addOns        AddOn[]
  notifications Notification[]

  @@index([status])
  @@index([slug])
}

model TenantSettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Branding
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String  @default("#0d9488")
  accentColor    String  @default("#f59e0b")
  companySlogan  String?
  companyWebsite String?
  companyAddress String?
  companyCity    String?
  companyState   String?
  companyZip     String?
  companyEin     String? // Tax ID / EIN (opcional)
  supportEmail   String?
  supportPhone   String?
  whatsappNumber String?

  // Áreas atendidas
  cities   String[]
  timezone String   @default("America/New_York")

  // Horários de funcionamento
  workDays           Int[] @default([1, 2, 3, 4, 5, 6])
  startHour          Int   @default(8)
  endHour            Int   @default(18)
  minAdvanceHours    Int   @default(24)
  travelBlockMinutes Int   @default(40)

  // Preços configuráveis por tenant — cômodos com quantidade
  basePrice          Decimal @default(35.00) @db.Decimal(10, 2)
  pricePerBedroom    Decimal @default(25.00) @db.Decimal(10, 2)
  pricePerBathroom   Decimal @default(20.00) @db.Decimal(10, 2)
  pricePerLivingRoom Decimal @default(15.00) @db.Decimal(10, 2)
  pricePerDiningRoom Decimal @default(12.00) @db.Decimal(10, 2)
  pricePerKitchen    Decimal @default(20.00) @db.Decimal(10, 2)
  pricePerOffice     Decimal @default(15.00) @db.Decimal(10, 2)
  pricePerGarage     Decimal @default(30.00) @db.Decimal(10, 2)

  // Preços configuráveis por tenant — áreas extras (toggle)
  priceLaundry  Decimal @default(20.00) @db.Decimal(10, 2)
  pricePool     Decimal @default(35.00) @db.Decimal(10, 2)
  pricePatio    Decimal @default(25.00) @db.Decimal(10, 2)
  priceBalcony  Decimal @default(15.00) @db.Decimal(10, 2)
  priceBasement Decimal @default(30.00) @db.Decimal(10, 2)
  priceAttic    Decimal @default(25.00) @db.Decimal(10, 2)
  priceGym      Decimal @default(20.00) @db.Decimal(10, 2)
  priceGameRoom Decimal @default(20.00) @db.Decimal(10, 2)

  // Legado
  priceExtraRoom Decimal @default(15.00) @db.Decimal(10, 2)
  priceGarage    Decimal @default(30.00) @db.Decimal(10, 2)

  // Descontos por recorrência
  discountWeekly    Int @default(10) // % desconto semanal
  discountBiweekly  Int @default(8)  // % desconto quinzenal
  discountMonthly   Int @default(5)  // % desconto mensal

  // Multiplicador para deep cleaning (ex: 135 = +35%)
  deepCleaningMultiplier Int @default(135)

  // Cobrar hold no cartão antes (true) ou cobrar direto (false)
  useHoldCapture Boolean @default(false)

  // Duração estimada
  baseDurationMinutes   Int @default(90)
  durationPerBedroom    Int @default(30)
  durationPerBathroom   Int @default(20)
  durationPerLivingRoom Int @default(15)
  durationPerDiningRoom Int @default(10)
  durationPerKitchen    Int @default(20)
  durationPerOffice     Int @default(15)
  durationPerGarage     Int @default(20)

  updatedAt DateTime @updatedAt
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  email           String
  hashedPassword  String?
  emailVerified   DateTime?
  image           String?
  role            Role      @default(CLIENT)
  isPlatformAdmin Boolean   @default(false)
  phone           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts   Account[]
  sessions   Session[]
  properties Property[]
  bookings   Booking[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domínio ──────────────────────────────────────────────────────────────────

model Property {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  nickname String
  address  String
  city     String

  // Cômodos com quantidade
  bedrooms    Int
  bathrooms   Int
  livingRooms Int @default(1) // salas de estar
  diningRooms Int @default(0) // salas de jantar
  kitchens    Int @default(1) // cozinhas
  offices     Int @default(0) // escritórios / home office
  garages     Int @default(0) // vagas de garagem

  // Áreas extras (toggle)
  hasLaundry  Boolean @default(false) // lavanderia
  hasPool     Boolean @default(false) // área da piscina
  hasPatio    Boolean @default(false) // pátio / área externa
  hasBalcony  Boolean @default(false) // varanda / sacada
  hasBasement Boolean @default(false) // porão / subsolo
  hasAttic    Boolean @default(false) // sótão
  hasGym      Boolean @default(false) // academia / sala de exercícios
  hasGameRoom Boolean @default(false) // sala de jogos / home theater

  // Tipo de imóvel
  propertyType String @default("house") // "house" | "apartment" | "condo" | "office"

  // Acesso ao imóvel
  accessType    String  @default("client_present") // "client_present" | "lockbox" | "gate_code" | "key_hidden" | "doorman" | "other"
  accessCode    String? // código do gate, lockbox, etc.
  accessNotes   String? // instruções detalhadas de acesso
  cleaningNotes String? // observações especiais de limpeza (alergias, pets, áreas a evitar)

  // Áreas específicas para limpeza (array de strings)
  cleaningAreas String[] @default([])

  // Legado — mantido para compatibilidade (substituído por offices + garages)
  extraRooms Int     @default(0)
  hasGarage  Boolean @default(false)

  // Agendamento recorrente
  cleaningType String  @default("standard") // "standard" | "deep"

  calculatedPrice Decimal  @db.Decimal(10, 2)
  customPrice     Decimal? @db.Decimal(10, 2) // preço personalizado definido pelo admin (sobrescreve calculatedPrice)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([tenantId])
  @@index([tenantId, userId])
}

model Team {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  color     String   @default("#3B82F6")
  createdAt DateTime @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings   Booking[]
  timeBlocks TimeBlock[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model Booking {
  id                    String        @id @default(cuid())
  tenantId              String
  userId                String
  propertyId            String
  teamId                String?
  scheduledAt           DateTime
  estimatedDuration     Int
  price                 Decimal       @db.Decimal(10, 2)
  status                BookingStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeSessionId       String?       @unique
  notes                 String?

  // Tipo de serviço e recorrência
  cleaningType          String        @default("standard") // "standard" | "deep"
  frequency             String        @default("once")     // "once" | "weekly" | "biweekly" | "monthly"
  recurringDiscount     Decimal       @default(0.00) @db.Decimal(5, 2) // % de desconto aplicado
  parentBookingId       String?       // referência ao booking pai (recorrências filhas)

  // Stripe hold/capture (pre-autorização)
  stripeHoldCapture     Boolean       @default(false) // true = cobrado só após conclusão

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])
  property      Property       @relation(fields: [propertyId], references: [id])
  team          Team?          @relation(fields: [teamId], references: [id])
  timeBlocks    TimeBlock[]
  bookingAddOns BookingAddOn[]
  notifications Notification[]

  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, status])
  @@index([userId])
}

// ─── Serviços adicionais ──────────────────────────────────────────────────────

model AddOn {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  price           Decimal  @db.Decimal(8, 2)
  durationMinutes Int      @default(0)
  icon            String? // emoji ou nome de ícone
  category        String   @default("general") // "kitchen" | "garage" | "glass" | "outdoor" | "general"
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingAddOns BookingAddOn[]

  @@index([tenantId, isActive])
}

model BookingAddOn {
  id        String  @id @default(cuid())
  bookingId String
  addOnId   String
  price     Decimal @db.Decimal(8, 2) // snapshot do preço no momento da reserva

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOn   AddOn   @relation(fields: [addOnId], references: [id])

  @@unique([bookingId, addOnId])
}

model TimeBlock {
  id             String        @id @default(cuid())
  tenantId       String
  startAt        DateTime
  endAt          DateTime
  type           TimeBlockType
  bookingId      String?
  teamId         String?
  createdByAdmin Boolean       @default(false)
  createdAt      DateTime      @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  team    Team?    @relation(fields: [teamId], references: [id])

  @@index([tenantId])
  @@index([tenantId, teamId, startAt, endAt])
  @@index([startAt])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  bookingId String?
  type      String   @default("BOOKING_CONFIRMED")
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tenantId, read])
  @@index([tenantId, createdAt])
}

model Waitlist {
  id          String   @id @default(cuid())
  companyName String
  ownerName   String
  email       String
  phone       String?
  city        String?
  teamCount   String? // "1", "2-5", "6+"
  message     String?
  source      String   @default("para-empresas") // qual página gerou o lead
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
